# ============================================================
# IGNIS Orbital API — Variáveis de Ambiente
# Copie este arquivo para .env e ajuste os valores.
# NUNCA commite o .env com valores reais.
# ============================================================

# Aplicação
APP_ENV=development
DEBUG=true
APP_VERSION=0.1.0

# Banco de dados (usado pelo FastAPI/SQLAlchemy — driver asyncpg)
DATABASE_URL=postgresql+asyncpg://ignis:ignis_secret@db:5432/ignis_db

# Banco de dados (variáveis individuais usadas pelo Docker Compose)
POSTGRES_USER=ignis
POSTGRES_PASSWORD=ignis_secret
POSTGRES_DB=ignis_db
POSTGRES_HOST=db
POSTGRES_PORT=5432

# JWT
# Gere uma chave segura com: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your-super-secret-key-change-in-production-never-commit-this
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS — lista separada por vírgulas
CORS_ORIGINS=http://localhost:8080,http://localhost:5173,https://ignis-fire-watch-main.vercel.app
